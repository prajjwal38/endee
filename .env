GEMINI_API_KEY=paste_your_GEMINI_API_KEY
ENDEE_URL=http://localhost:8080
OPENAI_API_KEY=dummy

# (Optional) Endee auth token – leave blank if you haven't set NDD_AUTH_TOKEN
ENDEE_AUTH_TOKEN=

# Toggle Qwen3-Reranker (set to true to enable, false to skip)
ENABLE_RERANKER=false

# Ollama local model configuration (for LLM-assisted chunking)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b
